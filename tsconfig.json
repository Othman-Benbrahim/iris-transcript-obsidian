{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": false,
    "isolatedModules": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ES2018"]
  },
  "include": ["src/**/*.ts"]
}
